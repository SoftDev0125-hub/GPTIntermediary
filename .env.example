# =============================================================================
# GPT Intermediary - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for the features you want.
# On Windows portable build: put .env in the same folder as GPTIntermediary.exe.
# Leave optional variables empty or commented out if not needed.
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED: Google OAuth (login + Gmail)
# Get from: https://console.cloud.google.com/apis/credentials
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# -----------------------------------------------------------------------------
# REQUIRED: OpenAI API (AI chat and tools)
# Get from: https://platform.openai.com/api-keys
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-your_openai_api_key_here

# -----------------------------------------------------------------------------
# Gmail tokens (optional - filled automatically by GetGmailToken.exe)
# After running GetGmailToken.exe, these are written here; you can also set manually.
# -----------------------------------------------------------------------------
# USER_ACCESS_TOKEN=
# USER_REFRESH_TOKEN=
# USER_EMAIL=

# -----------------------------------------------------------------------------
# Server (optional – defaults work for local/portable)
# -----------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
DEBUG=True

# Desktop launcher (app.py on Windows): opens Edge/Chrome in application mode by default (not a normal browser tab).
# Uses data/chromium_app_profile/ so the browser stays a dedicated instance (not a short-lived launcher).
# DESKTOP_SHELL=webview  → try pywebview first (Python 3.11/3.12 + pip install pywebview).
# CHROMIUM_APP_EXE=      → optional full path to msedge.exe or chrome.exe if not auto-detected.

# -----------------------------------------------------------------------------
# Application settings (optional)
# -----------------------------------------------------------------------------
MAX_UNREAD_EMAILS=50
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Multi-tenant / hosted deployment (e.g. Hostinger, one app many users)
# -----------------------------------------------------------------------------
# When MULTI_TENANT_MODE=1 (or true): Gmail access uses each user's linked tokens in the
# database only; USER_ACCESS_TOKEN* in .env are not used for end users. Users must sign in
# (JWT); the chat server forwards Authorization to the API. Leave unset or 0 for single-user
# setups where .env tokens are OK.
# MULTI_TENANT_MODE=1

# -----------------------------------------------------------------------------
# Node integration servers (Telegram 3001, Slack 3002, WhatsApp 3000)
# When MULTI_TENANT_MODE=1, point these at the same SECRET_KEY as the Python API
# and set BACKEND_URL so Telegram/Slack Node processes can load per-user tokens:
# BACKEND_URL=http://127.0.0.1:8000
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Email finder (optional – "Find email of X", "Send to X's email", etc.)
# At least one key enables the feature. Bing = Azure Bing Search; People = e.g. Hunter.io
# -----------------------------------------------------------------------------
# BING_API_KEY=your_azure_bing_subscription_key
# BING_SEARCH_API_KEY=your_azure_bing_key
# PEOPLE_API_KEY=your_hunter_io_or_people_api_key
# HUNTER_API_KEY=alternative_to_PEOPLE_API_KEY
# CLEARBIT_API_KEY=optional_clearbit_key

# -----------------------------------------------------------------------------
# Telegram (optional – Telegram integration)
# Get API ID & Hash: https://my.telegram.org/apps
# -----------------------------------------------------------------------------
# TELEGRAM_API_ID=
# TELEGRAM_API_HASH=
# TELEGRAM_PHONE_NUMBER=+1234567890

# -----------------------------------------------------------------------------
# Slack (optional – Slack integration)
# User token (xoxp-): from Slack app OAuth; Bot token (xoxb-): for Socket Mode.
# For real-time events use SLACK_BOT_TOKEN + SLACK_APP_TOKEN (xapp-).
# -----------------------------------------------------------------------------
# SLACK_USER_TOKEN=xoxp-...
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...

# -----------------------------------------------------------------------------
# WhatsApp (Node whatsapp-web.js + Puppeteer)
# WHATSAPP_PORT=3000
# Very large chat lists: Puppeteer's default CDP timeout (~180s) can abort getChats(); default here is 600000 ms.
# WHATSAPP_PUPPETEER_PROTOCOL_TIMEOUT_MS=900000
# Max time after "ready" before treating chat APIs as safe; the sidebar still appears earlier if getChats() already finished.
# WHATSAPP_CHATS_WARMUP_MS=45000
# Start loading the full chat list this many ms after "ready" (default 3000). Lower = snappier; too low may increase rare getChats errors.
# WHATSAPP_CHATS_PREFETCH_MS=3000
# If you see no QR: install Google Chrome, OR download Chromium for Puppeteer:
#   npm run setup:puppeteer-chrome
# OR point to any Chrome/Chromium binary:
#   PUPPETEER_EXECUTABLE_PATH=C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe
# Optional: wait this many ms after "ready" before message fetch (default 0 = immediate, like earlier builds). Use 3000–8000 if you see rare empty first loads.
# WHATSAPP_MESSAGES_MIN_READY_MS=5000
# If logs show "waitForChatLoading" / getChatById failing inside web.whatsapp.com JS: Meta changed the web client.
# Pin an archived HTML build from https://github.com/wppconnect-team/wa-version/tree/main/html then restart the WhatsApp Node process:
# WHATSAPP_WEB_VERSION=2.3000.1037225082-alpha
# WHATSAPP_WEB_VERSION_CACHE_TYPE=remote
# WHATSAPP_WEB_VERSION_REMOTE_PATH=https://raw.githubusercontent.com/wppconnect-team/wa-version/main/html/{version}.html
# WHATSAPP_WEB_VERSION_STRICT=true

# -----------------------------------------------------------------------------
# Database (optional – leave DATABASE_URL empty for SQLite in data/gptintermediary.sqlite3)
# For PostgreSQL set: postgresql://user:password@host:port/dbname
# If .env points at PostgreSQL but the server is down, the app falls back to SQLite after a
# short timeout; set DATABASE_USE_SQLITE=1 to use SQLite only (no connect attempt to Postgres).
# Optional: DATABASE_CONNECT_TIMEOUT=10 (seconds, psycopg2 only)
# -----------------------------------------------------------------------------
# DATABASE_URL=
# DATABASE_USE_SQLITE=1

# -----------------------------------------------------------------------------
# Auth secret (optional – change in production)
# -----------------------------------------------------------------------------
# SECRET_KEY=your-secret-key-change-this-in-production

# -----------------------------------------------------------------------------
# News API — optional; not read by the app (you may keep an existing key in .env unchanged).
# Web results use Google Custom Search when configured (see below).
# -----------------------------------------------------------------------------
# NEWSAPI_KEY=

# -----------------------------------------------------------------------------
# Google Custom Search (optional — /api/news and chat grounding for non-technical queries)
# API key: https://developers.google.com/custom-search/v1/overview
# Search engine ID (cx): https://programmablesearchengine.google.com/
# -----------------------------------------------------------------------------
# GOOGLE_CUSTOM_SEARCH_API_KEY=
# GOOGLE_CUSTOM_SEARCH_ENGINE_ID=

# Optional: model used to classify "technical" (OpenAI-only) vs general (Google+Bing) in chat
# OPENAI_TECHNICAL_CLASSIFIER_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# OpenAI retries (optional)
# -----------------------------------------------------------------------------
# OPENAI_MAX_RETRIES=4
# OPENAI_RETRY_BASE_DELAY=1.0

# -----------------------------------------------------------------------------
# OpenAI Realtime voice (optional – Chat tab: voice engine "OpenAI Realtime")
# Uses the same OPENAI_API_KEY. Browser WebRTC offer is proxied via chat_server POST /realtime/calls.
# -----------------------------------------------------------------------------
# OPENAI_REALTIME_MODEL=gpt-realtime
# OPENAI_REALTIME_VOICE=marin

# -----------------------------------------------------------------------------
# OpenAI voice pipeline (optional – Chat: voice engine "OpenAI: STT → chat → TTS")
# Whisper transcribes audio; gpt-4o-mini classifies question vs command; same /chat as text UI; TTS speaks the reply.
# -----------------------------------------------------------------------------
# OPENAI_WHISPER_MODEL=whisper-1
# OPENAI_INTENT_MODEL=gpt-4o-mini
# OPENAI_TTS_MODEL=tts-1
# OPENAI_TTS_VOICE=alloy
# VOICE_MAX_UPLOAD_BYTES=26214400
